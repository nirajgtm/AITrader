# Trader API keys — template (do NOT put real values here).
#
# To use: copy to ~/claude-configs/trader/.env and fill in values.
#   cp .env.example .env
#   chmod 600 .env

# ===== Active providers =====

# public.com — brokerage API: REAL-TIME quotes, market data, options chains/greeks,
# account/positions, and order placement (live — no sandbox). This is the personal
# SECRET key (32-char), not a bearer token; the client exchanges it for short-lived
# JWTs. Powers the CLI (`public`), the MCP server, and trader quote scripts.
# Get it: public.com account settings -> API (Individual Trader API Program).
PUBLIC_BROKER_API=
# The brokerage account ID (from `public accounts list`, the BUY_AND_SELL one).
# Required by nearly every market-data and trading path (paths are account-scoped).
PUBLIC_COM_ACCOUNT_ID=


# AlphaVantage — fundamentals + technical indicators.
# Sign up: https://www.alphavantage.co/support/#api-key
# Free tier: 25 requests/day, 5 requests/minute. Cache hard. Reserve for high-value calls.
ALPHAVANTAGE_API_KEY=

# Finnhub — news, earnings calendar, insider sentiment, recommendations.
# Sign up: https://finnhub.io/dashboard
# Free tier: 60 requests/minute. Use for news/sentiment/earnings cal.
FINNHUB_API_KEY=

# Financial Modeling Prep — economic calendar, ratios, DCF, ratings.
# Sign up: https://site.financialmodelingprep.com/developer/docs
# Free tier: 250 requests/day. Cache 6-12h.
FMP_API_KEY=

# Massive — residential proxy / web unblocking (for scrape fallbacks).
# Sign up: https://massive.com/
MASSIVE_API_KEY=

# ===== Recommended additions (free) =====

# FRED — US macro data (CPI, jobs, rates).
# Sign up: https://fredaccount.stlouisfed.org/apikey
# Unlimited free. Optional — keyless fallback exists.
FRED_API_KEY=

# CoinGecko — crypto prices, trending, BTC dominance.
# Sign up: https://www.coingecko.com/en/developers/dashboard
# Free demo key: 30 req/min. Without key: ~5 req/min (heavily rate-limited).
COINGECKO_DEMO_API_KEY=

# Quiver Quant — congressional trades, insider sentiment, WSB sentiment.
# Sign up: https://api.quiverquant.com/account/register
# Free tier exists; replaces brittle capitoltrades scraping.
QUIVER_API_KEY=

# Marketaux — pre-scored sentiment news (financial).
# Sign up: https://www.marketaux.com/account/register
# Free tier: 100 req/day.
MARKETAUX_API_KEY=

# Tiingo — clean stock data + news (alternate to yfinance).
# Sign up: https://www.tiingo.com/account/api/token
# Free tier: 50 req/hr.
TIINGO_API_KEY=

# SEC EDGAR contact email — required by SEC in the User-Agent header for EDGAR API calls.
# Use any valid email address you own. See: https://www.sec.gov/os/accessing-edgar-data
SEC_CONTACT_EMAIL=

# ===== Published site =====

# Public market-watch site URL (your own GitHub Pages page). Used only in the publish
# success message that the trader skill prints. Set to your Pages URL, for example
# https://<your-username>.github.io/<your-repo>/
MARKET_WATCH_URL=
